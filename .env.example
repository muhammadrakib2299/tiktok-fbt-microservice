# =======================================================================
# These environment variables are APPENDED to the existing
# tiktok-microservice/.env and tiktok-microservice/.env.example.
#
# DO NOT create a new env file or new microservice. FBT lives inside the
# existing tiktok-microservice as a new src/modules/fbt/ submodule.
#
# The existing variables (DB_*, TIKTOK_APP_KEY, TIKTOK_APP_SECRET,
# RABBITMQ_*, TOKEN_ENCRYPTION_KEY, etc.) ARE REUSED for FBT — no new
# credentials or app registrations needed unless TikTok forces it.
# =======================================================================

# ----- FBT region scope -----
# Comma-separated list of regions this instance serves FBT for.
# Phase 1: UK only. Phase 2+: add US.
FBT_ENABLED_REGIONS=GB

# ----- Server-side feature gates -----
# These complement the per-merchant feature flag (tiktok_fbt in
# subscription_features). Both must be true for FBT processing to run.
FBT_ENABLE_INVENTORY_SYNC=true
FBT_ENABLE_ORDER_SYNC=true
FBT_ENABLE_WEBHOOKS=true

# Phase 2 — leave false until Phase 2 ships
FBT_ENABLE_INBOUND_SHIPMENTS=false

# Phase 3 — leave false until Phase 3 ships
FBT_ENABLE_FEES_INGESTION=false
FBT_ENABLE_DISPUTE_SUBMISSION=false

# ----- Cron schedules -----
FBT_INVENTORY_CRON=0 */15 * * * *
FBT_ORDERS_CRON=0 */5 * * * *
FBT_INBOUND_STATUS_CRON=0 */30 * * * *
FBT_STATEMENT_CRON=15 3 * * *

# ----- Per-account stagger (seconds) to spread rate-limit load -----
FBT_ACCOUNT_STAGGER_SECONDS=30

# ----- Hard ceiling on outbound TikTok requests per minute, per region -----
FBT_RATE_LIMIT_PER_MINUTE_GB=50
FBT_RATE_LIMIT_PER_MINUTE_US=50

# ----- OPTIONAL: separate TikTok app credentials for FBT -----
# Only set these if TikTok requires a separate app registration for FBT
# scope grants. See 07-risks-and-open-questions.md §A3. If unset, the
# existing TIKTOK_APP_KEY / TIKTOK_APP_SECRET cover both seller and FBT.
#
# TIKTOK_FBT_APP_KEY=...
# TIKTOK_FBT_APP_SECRET=...
