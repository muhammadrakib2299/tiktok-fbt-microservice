# Application
PORT=5018
NODE_ENV=development

# Database (new microservice's own DB)
DB_HOST=109.199.97.148
DB_PORT=5432
DB_USERNAME=combosoft
DB_PASSWORD=Combosot_000
DB_NAME=tiktok_fbt_microservice

# WMS Database (read-only access for catalogue + variations lookup)
# NOTE: locally the WMS DB is wms_v2; production is combosoft_wms_db.
# Always set WMS_DB_NAME explicitly in your local .env to avoid the wrong default.
WMS_DB_HOST=localhost
WMS_DB_PORT=5432
WMS_DB_USERNAME=postgres
WMS_DB_PASSWORD=postgres
WMS_DB_NAME=combosoft_wms_db

# TikTok Shop API (FBT)
# Open question (week 1 research): same TIKTOK app key/secret as the seller integration,
# or a separately-registered TikTok app for FBT? Default assumption is separate registration.
TIKTOK_FBT_APP_KEY=your_fbt_app_key
TIKTOK_FBT_APP_SECRET=your_fbt_app_secret
TIKTOK_FBT_REDIRECT_URI=http://localhost:5018/api/tiktok-fbt/auth/callback
TIKTOK_FBT_API_BASE_URL=https://open-api.tiktokglobalshop.com

# Token Encryption (AES-256-GCM, 32-byte hex)
# MUST be a different key from tiktok-microservice's TOKEN_ENCRYPTION_KEY.
# Cross-service token decryption is never supported.
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# RabbitMQ (shares the same exchange `wms_multichannel` with other microservices)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=wms_multichannel

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# FBT regions this instance serves
FBT_ENABLED_REGIONS=GB

# Phase-1 feature gates (server-side defence in depth; per-merchant flag also enforced)
FBT_ENABLE_INVENTORY_SYNC=true
FBT_ENABLE_ORDER_SYNC=true
FBT_ENABLE_WEBHOOKS=true

# Phase 2 — off until Phase 2 ships
FBT_ENABLE_INBOUND_SHIPMENTS=false

# Phase 3 — off until Phase 3 ships
FBT_ENABLE_FEES_INGESTION=false
FBT_ENABLE_DISPUTE_SUBMISSION=false

# Cron schedules
FBT_INVENTORY_CRON=0 */15 * * * *
FBT_ORDERS_CRON=0 */5 * * * *
FBT_INBOUND_STATUS_CRON=0 */30 * * * *
FBT_STATEMENT_CRON=15 3 * * *
FBT_TOKEN_REFRESH_CRON=0 5,35 * * * *

# Per-account stagger (seconds) to spread rate-limit load
FBT_ACCOUNT_STAGGER_SECONDS=30

# Hard ceilings on outbound TikTok requests per minute, per region
FBT_RATE_LIMIT_PER_MINUTE_GB=50
FBT_RATE_LIMIT_PER_MINUTE_US=50
